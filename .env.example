# ==============================================================================
# HoopRec Scraper — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env

# ── YouTube Data API (required for Phase 2) ───────────────────────────────────
# Get a key at https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable "YouTube Data API v3" for your project.
YOUTUBE_API_KEY=

# ── Google OAuth 2.0 (optional — YouTube commenting only) ─────────────────────
# Only needed if you want to post YouTube comments from the web UI.
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Ollama Models ─────────────────────────────────────────────────────────────
# LLM used for chat responses (RAG pipeline)
RAG_LLM_MODEL=llama3.1:8b
# Embedding model for the ChromaDB vector store
RAG_EMBED_MODEL=nomic-embed-text
# Model used by youtube-ingest to clean up transcript punctuation
OLLAMA_MODEL=llama3.1:8b

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set SKIP_OLLAMA=true to skip Ollama transcript cleaning (faster, lower quality)
SKIP_OLLAMA=false
# Set PRELOAD_SUGGESTIONS=true to pre-generate game suggestions on web startup
PRELOAD_SUGGESTIONS=false

# ── Web Server ────────────────────────────────────────────────────────────────
RAG_WEB_PORT=8000

# ── Scraper Tuning ────────────────────────────────────────────────────────────
# Seconds to wait for JavaScript to settle on each hooprec.com page
HOOPREC_DELAY=2.5
# Number of concurrent page fetches (keep low to be a polite scraper)
HOOPREC_CONCUR=3
# Ollama timeout for transcript cleaning, in seconds
OLLAMA_TIMEOUT=120

# ── RAG Tuning ────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_LLM_TIMEOUT=300.0
RAG_CONTEXT_WINDOW=8192
RAG_CHROMA_COLLECTION=hooprec_youtube

# ── Data Paths (uncomment to override — defaults are relative to project root) ─
# HOOPREC_DB=data/db/hooprec.sqlite
# HOOPREC_MD_DIR=data/raw/hooprec_md
# HOOPREC_JSON=data/raw/matches.json
# YOUTUBE_MD_DIR=data/raw/youtube_md
# CHROMA_DIR=data/db/chroma
